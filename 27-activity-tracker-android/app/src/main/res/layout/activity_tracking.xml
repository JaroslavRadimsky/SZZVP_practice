<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/trackingTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aktivita probiha"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/sensorStatusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:text="Pripravuji senzory" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/clockText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="00:00:00"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/stepsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="18dp"
            android:text="Kroky: 0"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/distanceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="8dp"
            android:text="Vzdalenost: 0 m"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/intensityText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="8dp"
            android:text="Intenzita: Klidova"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/sampleStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="16dp"
            android:text="Vzorky se ukladaji kazdych 5 sekund." />
    </LinearLayout>

    <Button
        android:id="@+id/stopButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Ukoncit a ulozit" />
</LinearLayout>
