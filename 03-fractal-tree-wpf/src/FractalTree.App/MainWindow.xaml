<Window x:Class="FractalTree.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fraktalni strom" Height="720" Width="1040" MinHeight="560" MinWidth="860">
    <DockPanel>
        <StackPanel DockPanel.Dock="Left" Width="250" Margin="12">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Fraktalni strom" Margin="0 0 0 12" />

            <TextBlock Text="Iterace" />
            <TextBox x:Name="IterationsInput" Text="9" Margin="0 4 0 10" />

            <TextBlock Text="Uhel" />
            <TextBox x:Name="AngleInput" Text="28" Margin="0 4 0 10" />

            <TextBlock Text="Koeficient zkracovani" />
            <TextBox x:Name="ShorteningInput" Text="0.72" Margin="0 4 0 10" />

            <TextBlock Text="Barva (#RRGGBB)" />
            <TextBox x:Name="ColorInput" Text="#176B47" Margin="0 4 0 16" />

            <UniformGrid Columns="2" Rows="4">
                <Button Content="Start" Margin="0 0 6 8" Click="Start_Click" />
                <Button Content="Stop" Margin="6 0 0 8" Click="Stop_Click" />
                <Button Content="Pauza" Margin="0 0 6 8" Click="Pause_Click" />
                <Button Content="Pokracovat" Margin="6 0 0 8" Click="Resume_Click" />
                <Button Content="Export" Margin="0 0 6 8" Click="Export_Click" />
                <Button Content="Import" Margin="6 0 0 8" Click="Import_Click" />
            </UniformGrid>

            <TextBlock x:Name="StatusText" Text="Pripraveno" Margin="0 12 0 0" TextWrapping="Wrap" />
        </StackPanel>

        <Border BorderBrush="#D0D7DE" BorderThickness="1" Margin="0 12 12 12" Background="#FAFBFC">
            <Canvas x:Name="TreeCanvas" ClipToBounds="True" />
        </Border>
    </DockPanel>
</Window>

