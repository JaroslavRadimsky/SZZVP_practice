<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <EditText
        android:id="@+id/feedUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="RSS URL"
        android:inputType="textUri"
        android:text="https://www.idnes.cz/rss" />

    <Button
        android:id="@+id/loadButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nacist RSS kanal" />

    <Button
        android:id="@+id/demoButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nacist offline demo" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:text="Pripraveno" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rssList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp" />
</LinearLayout>
